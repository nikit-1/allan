{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "target": "ES2020",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "lib": ["ES2020", "dom"]
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts"],
    "exclude": ["node_modules"]
}
